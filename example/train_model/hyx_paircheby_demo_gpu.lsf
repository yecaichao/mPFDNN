#!/bin/bash
#BSUB -J hyx_paircheby
#BSUB -q gpu-phy-zhangwq
#BSUB -n 1
#BSUB -e %J.err
#BSUB -o %J.out
#BSUB -gpu "num=1/host"

set -euo pipefail

cd "$LS_SUBCWD"

export PYTHONUNBUFFERED=1
export PYTHONPATH="/work/phy-weigw/mPFDNN-opt-v1-pair-cheby-radial${PYTHONPATH:+:$PYTHONPATH}"

PYTHON_BIN="/work/phy-weigw/mPFDNN/env/bin/python"

unzip -q -o dataset.zip

$PYTHON_BIN - <<'PY'
import pathlib
import torch
import e3nn
import ptagnn

print("cwd", pathlib.Path.cwd())
print("torch", torch.__version__)
print("cuda_available", torch.cuda.is_available())
print("device_count", torch.cuda.device_count())
print("e3nn", e3nn.__version__)
print("ptagnn", pathlib.Path(ptagnn.__file__).resolve())

if not torch.cuda.is_available():
    raise SystemExit("CUDA is not available in the submitted job environment")
PY

$PYTHON_BIN my_run_train.py \
    --gate=None \
    --device="cuda" \
    --train_file=dataset/train_data0.xyz \
    --test_file=dataset/test_data0.xyz \
    --valid_file=dataset/valid_data0.xyz \
    --name=paircheby \
    --E0s="average" \
    --loss='universal' \
    --energy_weight=1 \
    --forces_weight=10 \
    --compute_stress=True \
    --energy_key="energy" \
    --forces_key="forces" \
    --eval_interval=1 \
    --virials_weight=100 \
    --virials_key='virial' \
    --error_table='PerAtomMAE' \
    --model="FAMS_DNN" \
    --interaction_first="Residual_InteractionBlock" \
    --interaction="Residual_InteractionBlock" \
    --radial_type="pairwise_tanh_chebyshev" \
    --num_recursions=0 \
    --product=3 \
    --max_ell=3 \
    --r_max=6.0 \
    --max_L=0 \
    --num_channels=128 \
    --num_radial_basis=10 \
    --MLP_irreps="16x0e" \
    --scaling='rms_forces_scaling' \
    --num_workers=0 \
    --lr=0.005 \
    --weight_decay=1e-8 \
    --ema \
    --ema_decay=0.995 \
    --scheduler_patience=5 \
    --batch_size=16 \
    --valid_batch_size=16 \
    --max_num_epochs=10
